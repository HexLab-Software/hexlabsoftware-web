# Brevo transactional email — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
# A sender address verified in Brevo → Senders, Domains & Dedicated IPs
BREVO_SENDER_EMAIL=no-reply@hexlabsoftware.it
BREVO_SENDER_NAME=HexLab Software
# Optional: override the recipient (defaults to assistenza@hexlabsoftware.it)
CONTACT_TO_EMAIL=assistenza@hexlabsoftware.it

# reCAPTCHA Enterprise (the new "powered by Google Cloud" tier)
#   1. Site key is created at https://console.cloud.google.com/security/recaptcha
#      and is public — it is shipped to the browser via NEXT_PUBLIC_*.
#   2. Server verification hits the Enterprise API and needs:
#        - the Google Cloud project id the key was created in
#        - a GCP API key with the "reCAPTCHA Enterprise API" enabled
#          (restrict the key to that API and, ideally, your Vercel egress IPs)
#   3. Docs: https://cloud.google.com/recaptcha/docs/create-assessment-website
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_PROJECT_ID=
RECAPTCHA_API_KEY=

# PostHog product analytics — https://us.posthog.com/project/settings
# The project API key (phc_...) is public by design — it ships in the
# browser bundle and is write-only (ingest events, cannot read data).
# Kept as an env var so it can be swapped per environment and analytics
# can be disabled without a redeploy by unsetting it.
NEXT_PUBLIC_POSTHOG_KEY=
